APP_ENV="development"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/onlyclaw?schema=public"
LOG_LEVEL="debug"
AUTH_SECRET="replace-with-a-long-random-auth-secret"
ALLOW_DEMO_AUTH="false"
ALLOW_DEMO_DATA_FALLBACK="true"
MEDIA_SIGNING_SECRET="replace-with-a-long-random-media-signing-secret"
BILLING_PROVIDER="mock"
BILLING_PROVIDER_WEBHOOK_SECRET="replace-with-a-long-random-webhook-secret"
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS="300"
ALLOWED_MEDIA_HOSTS="images.example.com,cdn.example.com"
